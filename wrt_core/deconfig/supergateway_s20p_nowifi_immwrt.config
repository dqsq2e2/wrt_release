# ========================================
# Target Device - SuperGateway S20P (No WiFi)
# ========================================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_supergateway_s20p=y

# Remove WiFi drivers
CONFIG_TARGET_DEVICE_PACKAGES_mediatek_filogic_DEVICE_supergateway_s20p="-kmod-mt76 -kmod-mt76-connac -kmod-mt76-core -kmod-mt7915e -kmod-mt7915-firmware -kmod-mt7916-firmware -kmod-mt7986-firmware -mt7986-wo-firmware"

# Remove WiFi packages and UI
CONFIG_PACKAGE_hostapd-common=n
CONFIG_PACKAGE_wpad-basic-mbedtls=n
CONFIG_PACKAGE_wpad-basic-openssl=n
CONFIG_PACKAGE_wpad-mbedtls=n
CONFIG_PACKAGE_wpad-openssl=n
CONFIG_PACKAGE_iw=n
CONFIG_PACKAGE_iwinfo=n

# ========================================
# iStore Apps
# ========================================
# iStore Dependencies (must be enabled first)
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_PACKAGE_libuci-lua=y
CONFIG_PACKAGE_mount-utils=y
CONFIG_PACKAGE_taskd=y
CONFIG_PACKAGE_luci-lib-taskd=y
CONFIG_PACKAGE_luci-lib-xterm=y

# tar and its compression dependencies (完整依赖链)
CONFIG_PACKAGE_tar=y

# bzip2 support
CONFIG_PACKAGE_bzip2=y
CONFIG_PACKAGE_libbz2=y

# xz/lzma support
CONFIG_PACKAGE_xz=y
CONFIG_PACKAGE_xz-utils=y
CONFIG_PACKAGE_liblzma=y

# zstd support
CONFIG_PACKAGE_libzstd=y

# ACL and xattr support
CONFIG_PACKAGE_libacl=y
CONFIG_PACKAGE_libattr=y

# tar feature flags
CONFIG_PACKAGE_TAR_BZIP2=y
CONFIG_PACKAGE_TAR_GZIP=y
CONFIG_PACKAGE_TAR_XZ=y
CONFIG_PACKAGE_TAR_ZSTD=y
CONFIG_PACKAGE_TAR_POSIX_ACL=y
CONFIG_PACKAGE_TAR_XATTR=y

# iStore Main App (Application Store)
CONFIG_PACKAGE_luci-app-store=y
CONFIG_PACKAGE_luci-i18n-store-zh-cn=y

# iStore Quick Start (Homepage)
CONFIG_PACKAGE_quickstart=y
CONFIG_PACKAGE_luci-app-quickstart=y
CONFIG_PACKAGE_luci-i18n-quickstart-zh-cn=y

# iStore Enhance
CONFIG_PACKAGE_istoreenhance=y
CONFIG_PACKAGE_luci-app-istoreenhance=y
CONFIG_PACKAGE_luci-i18n-istoreenhance-zh-cn=y

# iStore Other Apps
CONFIG_PACKAGE_luci-app-ddnsto=y
CONFIG_PACKAGE_luci-app-fastnet=y
CONFIG_PACKAGE_luci-app-floatip=y

# ========================================
# Proxy - OpenClash
# ========================================
CONFIG_PACKAGE_luci-app-openclash=y

# ========================================
# Docker (已禁用 - VIKINGYFY 源码不兼容 nftables)
# ========================================
# VIKINGYFY 源码的 Docker 包仍然依赖 iptables，与 firewall4 nftables 冲突
# 如需 Docker，请使用 C佬源码（chasey-dev/immortalwrt-mt798x-rebase）
CONFIG_PACKAGE_luci-app-dockerman=n
CONFIG_PACKAGE_docker=n
CONFIG_PACKAGE_dockerd=n
CONFIG_PACKAGE_docker-compose=n

# 禁用 Docker 相关的内核模块（避免拉入 iptables 依赖）
CONFIG_PACKAGE_kmod-nf-ipvs=n
CONFIG_PACKAGE_kmod-br-netfilter=n
CONFIG_PACKAGE_kmod-ip6tables=n

# ========================================
# Disk Management
# ========================================
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_parted=y
CONFIG_PACKAGE_smartmontools=y
CONFIG_PACKAGE_blockd=y

# Disk Tools
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_f2fs-tools=y
CONFIG_PACKAGE_btrfs-progs=y
CONFIG_PACKAGE_ntfs-3g=y
CONFIG_PACKAGE_ntfs-3g-utils=y

# ========================================
# Task Scheduler
# ========================================
CONFIG_PACKAGE_luci-app-taskplan=y

# ========================================
# Themes
# ========================================
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-theme-aurora=y
CONFIG_PACKAGE_luci-app-aurora-config=y

# ========================================
# File System Support
# ========================================
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-f2fs=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-btrfs=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-fs-autofs4=y
CONFIG_PACKAGE_kmod-fs-ksmbd=y

# Disk Tools
CONFIG_PACKAGE_kmod-mmc=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_gdisk=y
CONFIG_PACKAGE_cfdisk=y
CONFIG_PACKAGE_sgdisk=y
CONFIG_PACKAGE_blkid=y
CONFIG_PACKAGE_blockdev=y
CONFIG_PACKAGE_losetup=y
CONFIG_PACKAGE_dosfstools=y
CONFIG_PACKAGE_exfat-mkfs=y
CONFIG_PACKAGE_f2fsck=y
CONFIG_PACKAGE_mkf2fs=y

# NLS Support
CONFIG_PACKAGE_kmod-nls-base=y
CONFIG_PACKAGE_kmod-nls-cp437=y
CONFIG_PACKAGE_kmod-nls-iso8859-1=y
CONFIG_PACKAGE_kmod-nls-utf8=y

# ========================================
# USB Support
# ========================================
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb-uhci=y
CONFIG_PACKAGE_kmod-usb-xhci=y
CONFIG_PACKAGE_kmod-usb-dwc3=y

# USB Network
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-asix=y
CONFIG_PACKAGE_kmod-usb-net-asix-ax88179=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-net-rtl8150=y
CONFIG_PACKAGE_kmod-usb-net-rtl8152=y

# USB Tools
CONFIG_PACKAGE_usb-modeswitch=y
CONFIG_PACKAGE_usbutils=y

# ========================================
# Network Tools
# ========================================
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_ethtool=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_ip-full=y

# ========================================
# Other Kernel Modules
# ========================================
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_PACKAGE_kmod-dummy=y
CONFIG_PACKAGE_kmod-veth=y
CONFIG_PACKAGE_kmod-sched-core=y
CONFIG_PACKAGE_kmod-sched-cake=y
CONFIG_PACKAGE_kmod-ifb=y
CONFIG_PACKAGE_kmod-macvlan=y
CONFIG_PACKAGE_kmod-vxlan=y
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_kmod-bonding=y
CONFIG_PACKAGE_kmod-nvme=y
CONFIG_PACKAGE_kmod-scsi-core=y

# MediaTek Hardware Acceleration
CONFIG_PACKAGE_kmod-mediatek_hnat=y

# ========================================
# TurboACC
# ========================================
CONFIG_PACKAGE_luci-app-turboacc-mtk=y
CONFIG_PACKAGE_luci-i18n-turboacc-mtk-zh-cn=y
# Enable fastpath for better performance (Docker basic functions work fine)
# CONFIG_PACKAGE_TURBOACC_INCLUDE_NO_FASTPATH is not set

# ========================================
# Additional Apps
# ========================================
CONFIG_PACKAGE_luci-app-firewall=y

# ========================================
# Libraries
# ========================================
CONFIG_PACKAGE_libatomic=y
CONFIG_PACKAGE_libblkid=y
CONFIG_PACKAGE_libcap=y
CONFIG_PACKAGE_libcap-bin=y
CONFIG_PACKAGE_libcap-ng=y
CONFIG_PACKAGE_libncurses=y
CONFIG_PACKAGE_libpcap=y
CONFIG_PACKAGE_libstdcpp=y
CONFIG_PACKAGE_libuuid=y
CONFIG_PACKAGE_lua-cjson=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_pciutils=y
CONFIG_PACKAGE_mmc-utils=y

# ========================================
# File Sharing - Samba4
# ========================================
CONFIG_PACKAGE_luci-app-samba4=y

# ========================================
# Disable Unwanted Packages
# ========================================
CONFIG_PACKAGE_luci-app-wol=n
CONFIG_PACKAGE_luci-app-ddns=n
CONFIG_PACKAGE_luci-app-xlnetacc=n
CONFIG_PACKAGE_luci-app-unblockmusic=n
CONFIG_PACKAGE_luci-app-accesscontrol=n
CONFIG_PACKAGE_luci-app-uugamebooster=n
CONFIG_PACKAGE_luci-app-adbyby-plus=n
CONFIG_PACKAGE_luci-app-attendedsysupgrade=n
CONFIG_PACKAGE_luci-app-ssr-plus=n
CONFIG_PACKAGE_luci-app-homeproxy=n
CONFIG_PACKAGE_autosamba=n
CONFIG_PACKAGE_luci-app-cifs-mount=n

# Force disable passwall (proxy.config enables it by default)
CONFIG_PACKAGE_luci-app-passwall=n
CONFIG_PACKAGE_luci-app-passwall2=n
