# TARGET config
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_jdcloud_re-cp-03=y

# Kernel modules
CONFIG_PACKAGE_kmod-tls=y
CONFIG_PACKAGE_kmod-tun=y

# Package
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_fuse-utils=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_sgdisk=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_qrencode=y

# Enable Luci App
CONFIG_PACKAGE_luci-app-adguardhome=n
CONFIG_PACKAGE_luci-app-adguardhome_INCLUDE_binary=n
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-dockerman=n
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
# MediaTek Hardware Acceleration
CONFIG_PACKAGE_kmod-mediatek_hnat=y

# WARP (Wireless Acceleration and Routing Platform) - 有线和无线硬件加速
CONFIG_PACKAGE_kmod-warp=y
CONFIG_WARP_CHIPSET="mt7986"
CONFIG_WARP_VERSION=2
CONFIG_WARP_DBG_SUPPORT=y

# WED (Wireless Ethernet Dispatch) Hardware RRO Support
CONFIG_WED_HW_RRO_SUPPORT=y

# Flow Offload Support (硬件加速必需)
CONFIG_PACKAGE_kmod-nf-flow=y
CONFIG_PACKAGE_kmod-nf-nat=y
CONFIG_PACKAGE_kmod-nf-conntrack=y

# NFT NAT Support (nftables 版本，不依赖 iptables)
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-masq=y

# ========================================
# TurboACC
# ========================================
CONFIG_PACKAGE_luci-app-turboacc-mtk=y
CONFIG_PACKAGE_luci-i18n-turboacc-mtk-zh-cn=y

# TurboACC Options
# 禁用 FLOW_OFFLOADING（与 mtkhnat 冲突）
# CONFIG_PACKAGE_TURBOACC_INCLUDE_FLOW_OFFLOADING is not set
CONFIG_PACKAGE_TURBOACC_INCLUDE_BBR_CCA=y

